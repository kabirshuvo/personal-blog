# Application
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
WEB_ORIGIN=http://localhost:3000

# PostgreSQL
POSTGRES_USER=blog
POSTGRES_PASSWORD=blog
POSTGRES_DB=blog
POSTGRES_PORT=5432
DATABASE_URL=postgresql://blog:blog@localhost:5432/blog?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=blog-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Future auth and seed configuration
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-before-seeding
SEED_ADMIN_NAME=Site Administrator

# OAuth (optional — strategies register only when client id/secret are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# WebSocket base (omit to derive from NEXT_PUBLIC_API_URL host)
# NEXT_PUBLIC_WS_URL=http://localhost:4000

# SMTP (optional — emails log to console when SMTP_HOST is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
